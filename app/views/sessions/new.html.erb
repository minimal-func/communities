<% content_for :title, "Login" %>

<main class="login-shell">
  <section class="login-panel" aria-labelledby="login-title">
    <div class="login-copy">
      <p class="login-kicker">Communities</p>
      <h1 id="login-title">Member Login</h1>
      <p class="login-summary">Connect an invited Ethereum wallet to enter the community workspace.</p>
    </div>

    <% if current_member %>
      <div class="wallet-card">
        <div>
          <p class="wallet-label">Signed in wallet</p>
          <p class="wallet-address"><%= current_member.wallet_address %></p>
        </div>

        <div class="actions-row">
          <%= link_to "Invite wallet", new_wallet_invitation_path, class: "button" %>
          <%= button_to "Sign out", session_path, method: :delete, class: "button button-secondary" %>
        </div>
      </div>
    <% else %>
      <form class="wallet-card" data-controller="wallet-login" data-action="submit->wallet-login#submit">
        <fieldset class="provider-selector">
          <legend>Choose provider</legend>
          <button type="button"
                  class="provider-button provider-active"
                  data-provider-key="browser"
                  data-wallet-login-target="providerButton"
                  data-action="click->wallet-login#selectProvider">
            Browser Wallet
          </button>
          <button type="button"
                  class="provider-button provider-inactive"
                  data-provider-key="walletconnect"
                  data-wallet-login-target="providerButton"
                  data-action="click->wallet-login#selectProvider">
            WalletConnect
          </button>
          <button type="button"
                  class="provider-button provider-inactive"
                  data-provider-key="ledger"
                  data-wallet-login-target="providerButton"
                  data-action="click->wallet-login#selectProvider">
            Ledger
          </button>
        </fieldset>

        <div class="field">
          <label for="wallet_address">Wallet address</label>
          <input
            id="wallet_address"
            name="wallet_address"
            autocomplete="off"
            inputmode="text"
            placeholder="0x..."
            data-wallet-login-target="walletAddress"
          >
        </div>

        <div class="actions-row">
          <button type="button" data-action="wallet-login#connectWallet" data-wallet-login-target="connectButton">
            Connect wallet
          </button>

          <button type="submit" data-wallet-login-target="submitButton">
            Sign in
          </button>
        </div>

        <p class="login-status" data-wallet-login-target="status" role="status" aria-live="polite"></p>
      </form>
    <% end %>
  </section>
</main>
