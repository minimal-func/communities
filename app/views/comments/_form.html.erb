<%= form_with model: Comment.new, url: comments_path, local: true do |form| %>
  <%= form.hidden_field :post_id, value: @post.id %>

  <div
    data-controller="rich-text-editor"
    class="editor-shell"
  >
    <%= form.label :body, "Add a comment", class: "field-label" %>
    <div class="editor-toolbar" role="toolbar" aria-label="Formatting">
      <button type="button" data-command="bold" title="Bold (Ctrl+B)"><strong>B</strong></button>
      <button type="button" data-command="italic" title="Italic (Ctrl+I)"><em>I</em></button>
      <button type="button" data-command="underline" title="Underline (Ctrl+U)"><u>U</u></button>
      <button type="button" data-command="strike" title="Strikethrough"><s>S</s></button>
      <span class="toolbar-separator"></span>
      <button type="button" data-command="bulletList" title="Bullet List">&bull;</button>
      <button type="button" data-command="orderedList" title="Numbered List">1.</button>
      <button type="button" data-command="blockquote" title="Blockquote">&rdquo;</button>
      <button type="button" data-command="codeBlock" title="Code Block">{ }</button>
      <span class="toolbar-separator"></span>
      <button type="button" data-command="link" title="Link">&#8599;</button>
      <button type="button" data-command="image" title="Attach Image">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </button>
      <button type="button" data-emoji-toggle onclick="var p=this.parentElement.querySelector('.emoji-picker');if(p)p.style.display=p.style.display==='none'?'block':'none'" title="Emoji">😊</button>
      <div class="emoji-picker" data-rich-text-editor-target="emojiPicker" style="display:none">
        <div class="emoji-picker-row">
          <button type="button" class="emoji-picker-btn" data-emoji="😀">😀</button>
          <button type="button" class="emoji-picker-btn" data-emoji="😃">😃</button>
          <button type="button" class="emoji-picker-btn" data-emoji="😄">😄</button>
          <button type="button" class="emoji-picker-btn" data-emoji="😁">😁</button>
          <button type="button" class="emoji-picker-btn" data-emoji="😅">😅</button>
          <button type="button" class="emoji-picker-btn" data-emoji="😂">😂</button>
          <button type="button" class="emoji-picker-btn" data-emoji="🤣">🤣</button>
          <button type="button" class="emoji-picker-btn" data-emoji="😊">😊</button>
        </div>
        <div class="emoji-picker-row">
          <button type="button" class="emoji-picker-btn" data-emoji="😍">😍</button>
          <button type="button" class="emoji-picker-btn" data-emoji="🥰">🥰</button>
          <button type="button" class="emoji-picker-btn" data-emoji="😘">😘</button>
          <button type="button" class="emoji-picker-btn" data-emoji="😎">😎</button>
          <button type="button" class="emoji-picker-btn" data-emoji="👍">👍</button>
          <button type="button" class="emoji-picker-btn" data-emoji="👎">👎</button>
          <button type="button" class="emoji-picker-btn" data-emoji="❤️">❤️</button>
          <button type="button" class="emoji-picker-btn" data-emoji="🔥">🔥</button>
        </div>
        <div class="emoji-picker-row">
          <button type="button" class="emoji-picker-btn" data-emoji="✨">✨</button>
          <button type="button" class="emoji-picker-btn" data-emoji="🎉">🎉</button>
          <button type="button" class="emoji-picker-btn" data-emoji="💯">💯</button>
          <button type="button" class="emoji-picker-btn" data-emoji="⭐">⭐</button>
          <button type="button" class="emoji-picker-btn" data-emoji="🐶">🐶</button>
          <button type="button" class="emoji-picker-btn" data-emoji="🍕">🍕</button>
          <button type="button" class="emoji-picker-btn" data-emoji="🎈">🎈</button>
          <button type="button" class="emoji-picker-btn" data-emoji="🙌">🙌</button>
        </div>
      </div>
    </div>
    <div data-rich-text-editor-target="editor"></div>
    <%= form.hidden_field :body, data: { rich_text_editor_target: "input" } %>
    <input type="file" data-rich-text-editor-target="fileInput" accept="image/*" hidden>
  </div>

  <%= form.submit "Post Comment" %>
<% end %>