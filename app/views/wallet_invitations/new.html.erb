<% content_for :title, "Invite Wallet" %>

<main class="login-shell">
  <section class="login-panel invitation-panel" aria-labelledby="invitation-title">
    <div class="login-copy">
      <p class="login-kicker">Invitations</p>
      <h1 id="invitation-title">Invite Wallet</h1>
      <p class="login-summary">Add an Ethereum wallet to the invite list so it can complete wallet login.</p>
    </div>

    <%= form_with model: @wallet_invitation, url: wallet_invitations_path, class: "wallet-card" do |form| %>
      <div class="field">
        <%= form.label :wallet_address, "Wallet address" %>
        <%= form.text_field :wallet_address, autocomplete: "off", inputmode: "text", placeholder: "0x..." %>
      </div>

      <div class="actions-row">
        <%= form.submit "Create invitation" %>
        <%= link_to "Back to login", login_path, class: "button button-secondary" %>
      </div>
    <% end %>
  </section>

  <section class="invitation-list" aria-labelledby="sent-invitations-title">
    <h2 id="sent-invitations-title">Sent Invitations</h2>

    <% if @wallet_invitations.any? %>
      <table>
        <thead>
          <tr>
            <th>Wallet</th>
            <th>Status</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <% @wallet_invitations.each do |invitation| %>
            <tr>
              <td><%= invitation.wallet_address %></td>
              <td><%= invitation.accepted_at? ? "Accepted" : "Pending" %></td>
              <td><%= time_tag invitation.created_at, invitation.created_at.to_fs(:short) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="empty-state">No invitations sent yet.</p>
    <% end %>
  </section>
</main>
