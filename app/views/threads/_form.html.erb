<%= form_with model: thread, url: thread.persisted? ? thread_path(thread) : community_threads_path(community), class: "panel" do |form| %>
  <% if thread.errors.any? %>
    <div id="error_explanation">
      <p><%= pluralize(thread.errors.count, "error") %> prevented this thread from being saved:</p>
      <ul>
        <% thread.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title %>
    <%= form.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= form.label :body %>
    <%= form.text_area :body, rows: 8 %>
  </div>

  <div class="actions-row">
    <%= form.submit %>
  </div>
<% end %>
